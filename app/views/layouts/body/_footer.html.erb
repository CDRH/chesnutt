<footer id="footer">
  <div class="container">
    <div class="footer_info">
      <div class="footer_logo">
        <a href="https://www.unl.edu" rel="external"><%= image_tag('footer_logo_unl.png', alt: "University of Nebraska–Lincoln") %></a>
      </div>
      <div class="footer_logo">
        <p class="cdrh_link"><%= t "general.cdrh_link_html" %></p>
      </div>
      <div class="footer_logo">
        <a href="https://www.newschool.edu/" rel="external"><%= image_tag('footer_logo_tns.png', alt: "The New School") %></a>
      </div>
      <div class="footer_logo">
        <a href="https://www.neh.gov/" rel="external"><%= image_tag('footer_logo_neh.jpg', alt: "National Endowment for the Humanities") %></a>
      </div>
      <div class="footer_logo">
        <a href="https://www.archives.gov/nhprc" rel="external"><%= image_tag('footer_logo_nhprc.jpg', alt: "National Archives - National Historical Publications and Records Commission") %></a>
      </div>
      <div class="footer_logo">
        <a href="https://www.wrhs.org/" rel="external"><%= image_tag('footer_logo_wrhs.png', alt: "Western Reserve Historical Society") %></a>
      </div>
    </div><!-- /footer_info -->

    <div class="footer_additional_info">
      <p>Artwork by <a href="https://www.katwiese.com/">Kat Wiese</a>.</p>
      
      <div class="footer_logo footer_bluesky">
        <p>
          <a href="https://bsky.app/profile/chesnuttarchive.bsky.social" rel="external">
            Follow us on Bluesky: @chesnuttarchive.bsky.social<br />
            <%= image_tag('footer_logo_bluesky.png', alt: "", role: "presentation") %>
          </a>
        </p>
      </div>

      <br/><br/>
      <p class="footer_content_warning">Please note: some of the materials on this site contain sensitive and potentially disturbing content.</p>

    </div>
  </div> <!-- /container -->
  <%= render_overridable("layouts/body", "back_to_top") %>
</footer><!-- /footer -->
